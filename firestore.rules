rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check user authenticated status
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get user document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check if requester has a specific role
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Read access control:
      // 1. A user can read their own profile.
      // 2. A Super-Admin can read any user profile (needed for the approval list).
      // 3. A Teacher/Admin can read profiles of students (role != 'pending_admin' and role != 'super-admin') to show names on dashboards.
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        hasRole('super-admin') || 
        (hasRole('admin') && resource.data.role != 'pending_admin' && resource.data.role != 'super-admin')
      );
      
      // Create: Users can create their own profile document on registration.
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Update:
      // 1. Users can update their own profile, but are forbidden from changing their 'role'.
      // 2. Super-Admins can update any profile (permits role changes like pending_admin -> admin).
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
        hasRole('super-admin')
      );

      allow delete: if false; // Profiles are kept for audit logs
    }

    // --- ROOMS (CLASSROOMS) COLLECTION ---
    match /rooms/{roomId} {
      // Authenticated users can read room data
      allow read: if isAuthenticated();
      // Only authenticated admins and super-admins can create rooms
      allow create: if (hasRole('admin') || hasRole('super-admin')) && request.resource.data.admin_id == request.auth.uid;
      // Only the room owner (or super-admin) can update or delete it
      allow update, delete: if (hasRole('admin') || hasRole('super-admin')) && resource.data.admin_id == request.auth.uid;
    }

    // --- RESULTS (TEST SUBMISSIONS) COLLECTION ---
    match /results/{resultId} {
      // Students can submit their test results
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      
      // A result can be read by the student submitter, or the admin/super-admin owner of the room
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid || 
        hasRole('super-admin') || (
          hasRole('admin') && 
          get(/databases/$(database)/documents/rooms/$(resource.data.room_key)).data.admin_id == request.auth.uid
        )
      );

      // Only the admin owner (or super-admin) can update a result score
      allow update: if (hasRole('admin') || hasRole('super-admin')) && 
        get(/databases/$(database)/documents/rooms/$(resource.data.room_key)).data.admin_id == request.auth.uid;
        
      allow delete: if false; // Results are immutable for compliance
    }

    // --- TRIGGER EMAIL (MAIL) COLLECTION ---
    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}
